<script>
const nav=document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>60));
const toggle=document.querySelector('.menu-toggle');
const menu=document.querySelector('header.nav nav');
toggle.addEventListener('click',()=>{const o=menu.classList.toggle('open');toggle.textContent=o?'✕':'☰';toggle.setAttribute('aria-expanded',o);});
menu.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{menu.classList.remove('open');toggle.textContent='☰';}));
const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}}),{threshold:.12});
document.querySelectorAll('.fade').forEach(el=>io.observe(el));
const moreBtn=document.getElementById('course-more');
if(moreBtn){moreBtn.addEventListener('click',()=>{
  const s=document.getElementById('courses');
  const open=s.classList.toggle('show-all');
  if(open){
    s.querySelectorAll('.ccard.more').forEach((el,i)=>setTimeout(()=>el.classList.add('in'),i*90));
    moreBtn.textContent='Show Fewer Courses';
  }else{
    moreBtn.textContent='See More Courses →';
    s.scrollIntoView({behavior:'smooth'});
  }
});}
document.querySelectorAll('.chinamap .pin').forEach(p=>{
  const go=()=>{const t=document.getElementById(p.dataset.target);if(!t)return;
    t.scrollIntoView({behavior:'smooth',block:'center'});
    t.classList.add('flash');setTimeout(()=>t.classList.remove('flash'),2200);};
  p.addEventListener('click',go);
  p.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();go();}});
});
document.querySelectorAll('.ex-nav').forEach(btn=>btn.addEventListener('click',()=>{
  const wrap=btn.closest('.ex-carousel, .hotel-carousel');if(!wrap)return;
  const track=wrap.querySelector('.ex-track, .hotel-row');if(!track||!track.firstElementChild)return;
  const step=track.firstElementChild.getBoundingClientRect().width+20;
  track.scrollBy({left:btn.classList.contains('next')?step:-step,behavior:'smooth'});
}));
/* ===== Hotel detail modal ===== */
const HOTELS={
 'peninsula-beijing':{
  name:'The Peninsula Beijing',loc:'Beijing, China',
  desc:'Set on Wangfujing in the heart of the capital, The Peninsula Beijing is a short walk from the Forbidden City and the city’s finest shopping. A sweeping top-to-bottom renovation created some of the most generous rooms and suites in Beijing, finished in a calm, residential style, with celebrated Cantonese dining at Huang Ting and the Peninsula’s famously polished service. An ideal base between rounds at the capital’s leading courses and days among its imperial landmarks.',
  imgs:['hotel-peninsula-beijing-card.jpg','hotel-peninsula-beijing-1.jpg','hotel-peninsula-beijing-2.jpg','hotel-peninsula-beijing-3.jpg','hotel-peninsula-beijing-4.jpg','hotel-peninsula-beijing-5.jpg','hotel-peninsula-beijing-6.jpg','hotel-peninsula-beijing-7.jpg'],
  journey:{name:'Imperial China',specs:'6–7 Nights · 3 Rounds',route:['Beijing','The Great Wall'],href:'imperial-china.html',img:'assets/img/sj-firsttime.jpg'}
 },
 'waldorf-shanghai':{
  name:'Waldorf Astoria Shanghai on the Bund',loc:'Shanghai, China',
  desc:'Occupying No. 2 on the Bund, with the storied 1911 Shanghai Club building at its heart, the Waldorf Astoria pairs restored colonial grandeur — including the famous Long Bar — with a contemporary tower above the Huangpu River. Generous rooms and a position at the foot of the Bund place both old and new Shanghai within easy reach, with the championship golf of Sheshan a straightforward drive away.',
  imgs:['hotel-waldorf-shanghai-card.jpg','hotel-waldorf-shanghai-1.jpg','hotel-waldorf-shanghai-2.jpg','hotel-waldorf-shanghai-3.jpg','hotel-waldorf-shanghai-4.jpg','hotel-waldorf-shanghai-5.jpg','hotel-waldorf-shanghai-6.jpg','hotel-waldorf-shanghai-7.jpg','hotel-waldorf-shanghai-8.jpg'],
  journey:{name:'Jiangnan & Modern China',specs:'6–7 Nights · 3 Rounds',route:['Shanghai','Hangzhou'],href:'jiangnan-modern-china.html',img:'assets/img/hero-shanghai-dusk.jpg'}
 },
 'banyan-tree-lijiang':{
  name:'Banyan Tree Lijiang',loc:'Lijiang, China',
  desc:'At more than 2,400 metres, Banyan Tree Lijiang’s stone-walled villas and private courtyards look directly onto the peaks of Jade Dragon Snow Mountain. Built in the local Naxi style on the edge of Shuhe Ancient Town, around 45 minutes from Lijiang’s airport, it suits travellers who want traditional architecture, mountain air and unhurried service between rounds beneath the snow line.',
  imgs:['hotel-banyan-tree-lijiang-card.jpg','hotel-banyan-tree-lijiang-1.jpg','hotel-banyan-tree-lijiang-2.jpg','hotel-banyan-tree-lijiang-3.jpg','hotel-banyan-tree-lijiang-4.jpg','hotel-banyan-tree-lijiang-5.jpg','hotel-banyan-tree-lijiang-6.jpg'],
  journey:{name:'South of the Clouds',specs:'10–12 Nights · 5–6 Rounds',route:['Kunming','Lijiang','Shangri-La'],href:'south-of-the-clouds.html',img:'assets/img/jadedragon-fairway.jpg'}
 },
 'jinmao-purelax':{
  name:'Jinmao Purelax Lijiang',loc:'Lijiang, China',
  desc:'Part of The Unbound Collection by Hyatt, Jinmao Purelax sits at Ganhaizi meadow on the slopes of Jade Dragon Snow Mountain — the closest luxury base to the peak itself. Every room, suite and villa opens onto a private balcony facing the mountain, and clear high-altitude nights bring some of Yunnan’s finest stargazing. Jade Dragon Snow Mountain Golf Club, the longest course in the world, is minutes away.',
  imgs:['hotel-jinmao-purelax-card.jpg','hotel-jinmao-purelax-1.jpg','hotel-jinmao-purelax-2.jpg','hotel-jinmao-purelax-3.jpg','hotel-jinmao-purelax-4.jpg','hotel-jinmao-purelax-5.jpg','hotel-jinmao-purelax-6.jpg'],
  journey:{name:'South of the Clouds',specs:'10–12 Nights · 5–6 Rounds',route:['Kunming','Lijiang','Shangri-La'],href:'south-of-the-clouds.html',img:'assets/img/jadedragon-fairway.jpg'}
 }
};
const hmodal=document.getElementById('hotel-modal');
if(hmodal){
  let gal=[],gi=0;
  const img=document.getElementById('hm-img');
  const show=i=>{gi=(i+gal.length)%gal.length;img.src='assets/img/'+gal[gi];};
  const open=id=>{
    const d=HOTELS[id];if(!d)return;
    document.getElementById('hm-name').textContent=d.name;
    document.getElementById('hm-tag').textContent=d.name;
    document.getElementById('hm-loc').textContent=d.loc;
    document.getElementById('hm-desc').textContent=d.desc;
    img.alt=d.name;
    document.getElementById('hm-jlink').textContent='View journeys featuring '+d.name+' ↓';
    document.getElementById('hm-expert-line').textContent='Contact us to include '+d.name+' in your journey.';
    document.getElementById('hm-jtitle').textContent='Journeys featuring '+d.name;
    document.getElementById('hm-jspecs').textContent=d.journey.specs;
    document.getElementById('hm-jname').textContent=d.journey.name;
    document.getElementById('hm-jroute').innerHTML=d.journey.route.join('<span>•</span>');
    document.getElementById('hm-jgo').href=d.journey.href;
    document.getElementById('hm-jimg').style.backgroundImage='url('+d.journey.img+')';
    gal=d.imgs;show(0);
    hmodal.classList.add('open');document.body.classList.add('hm-lock');
    hmodal.querySelector('.panel').scrollTop=0;
  };
  const close=()=>{hmodal.classList.remove('open');document.body.classList.remove('hm-lock');};
  document.querySelectorAll('.btn-view[data-hotel]').forEach(b=>b.addEventListener('click',()=>open(b.dataset.hotel)));
  hmodal.querySelectorAll('[data-close]').forEach(el=>el.addEventListener('click',close));
  hmodal.querySelector('.hg-nav.prev').addEventListener('click',()=>show(gi-1));
  hmodal.querySelector('.hg-nav.next').addEventListener('click',()=>show(gi+1));
  document.getElementById('hm-jlink').addEventListener('click',()=>document.getElementById('hm-journeys').scrollIntoView({behavior:'smooth',block:'start'}));
  document.addEventListener('keydown',e=>{if(e.key==='Escape')close();});
}
document.querySelectorAll('.bigcard').forEach(card=>{
  const link=card.querySelector('.foot a');if(!link)return;
  card.addEventListener('click',e=>{if(e.target.closest('a'))return;window.location.href=link.href;});
});
</script>
</body>
