<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Golf China — Private Golf Journeys &amp; Exclusive Club Access</title>
<link rel="icon" type="image/svg+xml" href="assets/img/favicon.svg">
<link rel="icon" type="image/png" sizes="32x32" href="assets/img/favicon-32.png">
<link rel="apple-touch-icon" href="assets/img/apple-touch-icon.png">
<meta name="description" content="China's first golf travel company. Private golf journeys built around exclusive club access, selective guest play and confirmed tee times — Nicklaus beneath the Great Wall, Coore &amp; Crenshaw on the Hainan coast — with seamless ground logistics nationwide.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ===== Golf China — design tokens (see DESIGN-SYSTEM.md) ===== */
:root{
  --ink:#14241c; --pine:#1f3d2e; --moss:#3f6f54;
  --cinnabar:#b4452f; --gold:#b89150;
  --ivory:#f6f1e7; --paper:#fffdf8; --mist:#e7e0d2;
  --lift:0 18px 50px -20px rgba(20,36,28,.4);
  --serif:'Cormorant Garamond',Georgia,serif;
  --sans:'Jost',-apple-system,Segoe UI,sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
html,body{overflow-x:clip}
body{font-family:var(--sans);font-size:17px;color:var(--ink);background:var(--ivory);line-height:1.6;font-weight:300;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:var(--serif);font-weight:500;line-height:1.08;letter-spacing:.2px}
img{max-width:100%;display:block}
a{color:inherit;text-decoration:none}
.eyebrow{font-family:var(--sans);font-size:13px;font-weight:500;letter-spacing:.28em;text-transform:uppercase;color:var(--gold)}
.container{max-width:1200px;margin:0 auto;padding:0 28px}
.btn{display:inline-block;font-family:var(--sans);font-size:14px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;padding:15px 30px;border-radius:2px;cursor:pointer;border:1px solid transparent;transition:.25s}
.btn-primary{background:var(--cinnabar);color:#fff}
.btn-primary:hover{background:#9c3927}
.btn-ghost{border-color:rgba(255,255,255,.6);color:#fff}
.btn-ghost:hover{background:#fff;color:var(--pine)}
.btn-line{font-family:var(--sans);font-size:13px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--cinnabar);border-bottom:1px solid rgba(180,69,47,.35);padding-bottom:3px;transition:.25s}
.btn-line:hover{border-color:var(--cinnabar)}
.fade{opacity:0;transform:translateY(24px);transition:.7s ease}
.fade.in{opacity:1;transform:none}

/* ===== NAV ===== */
header.nav{position:fixed;top:0;left:0;right:0;z-index:50;transition:.3s}
header.nav .bar{display:flex;align-items:center;justify-content:space-between;padding:18px 28px;max-width:1200px;margin:0 auto}
header.nav .logo{font-family:var(--serif);font-size:23px;color:#fff;letter-spacing:.5px;display:flex;align-items:center;gap:11px}
header.nav .logo .logo-mark{height:30px;width:auto;display:block}
header.nav .logo .logo-text{color:#fff}
header.nav .logo span{color:var(--gold)}
header.nav nav{display:flex;gap:30px;align-items:center}
header.nav nav a{font-size:14px;letter-spacing:.08em;color:#fff;opacity:.92;font-weight:400}
header.nav nav a:hover{color:var(--gold)}
header.nav .nav-cta{font-size:13px;letter-spacing:.12em;text-transform:uppercase;border:1px solid rgba(255,255,255,.5);padding:10px 20px;border-radius:2px}
header.nav.scrolled{background:var(--pine);box-shadow:0 2px 20px rgba(0,0,0,.18)}
header.nav.scrolled .bar{padding:12px 28px}
.menu-toggle{display:none;background:none;border:none;color:#fff;font-size:26px;cursor:pointer;z-index:60}
@media(max-width:960px){
  header.nav .bar{padding:14px 20px}
  header.nav nav{position:absolute;top:100%;left:0;right:0;flex-direction:column;align-items:stretch;gap:0;background:var(--pine);max-height:0;overflow:hidden;transition:max-height .35s ease;box-shadow:0 18px 40px rgba(0,0,0,.25)}
  header.nav nav.open{max-height:520px}
  header.nav nav a{padding:15px 22px;border-top:1px solid rgba(255,255,255,.1);font-size:15px;opacity:1}
  header.nav nav .nav-cta{border:none;border-top:1px solid rgba(255,255,255,.1);background:var(--cinnabar);text-align:center;border-radius:0}
  .menu-toggle{display:block}
}

/* ===== HERO ===== */
.hero{position:relative;min-height:100vh;display:flex;align-items:stretch;color:#fff;overflow:hidden}
.hero-slides{position:absolute;inset:0;z-index:0}
.hslide{position:absolute;inset:0;opacity:0}
.hslide.s1{opacity:1}
.hslide picture,.hslide img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.hslide.s1{animation:hslide1 24s infinite}
.hslide.s2{animation:hslide2 24s infinite}
.hslide.s3{animation:hslide3 24s infinite}
@keyframes hslide1{0%{opacity:1}28%{opacity:1}33%{opacity:0}95%{opacity:0}100%{opacity:1}}
@keyframes hslide2{0%{opacity:0}28%{opacity:0}33%{opacity:1}61%{opacity:1}66%{opacity:0}100%{opacity:0}}
@keyframes hslide3{0%{opacity:0}61%{opacity:0}66%{opacity:1}95%{opacity:1}100%{opacity:0}}
@media(prefers-reduced-motion:reduce){.hslide{animation:none!important}.hslide.s1{opacity:1}.hslide.s2,.hslide.s3{opacity:0}}
.hero .scrim{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(20,36,28,.62) 0%,rgba(20,36,28,.3) 38%,rgba(20,36,28,.16) 62%,rgba(20,36,28,.75) 100%)}
.hero-inner{position:relative;z-index:2;display:flex;flex-direction:column;justify-content:flex-start;padding-top:clamp(140px,19vh,200px);padding-bottom:9vh}
.hero h1{font-size:clamp(34px,4.2vw,52px);max-width:28ch;margin:14px 0 0;font-weight:500;text-wrap:balance}
.hero .hero-tag{font-family:var(--serif);font-style:italic;font-size:clamp(18px,2vw,23px);color:rgba(255,255,255,.92);max-width:34ch;margin-top:22px;padding-top:20px;position:relative}
.hero .hero-tag::before{content:"";position:absolute;top:0;left:0;width:52px;height:1px;background:var(--gold)}
.hero .actions{margin-top:auto;display:flex;gap:16px;flex-wrap:wrap}
.hero .scroll-hint{position:absolute;bottom:26px;left:50%;transform:translateX(-50%);z-index:2;font-size:11px;letter-spacing:.25em;text-transform:uppercase;opacity:.75}

/* ===== SECTION SHELL ===== */
section{padding:100px 0}
.section-head{max-width:680px;margin-bottom:54px}
.section-head h2{font-size:clamp(32px,4.6vw,50px);margin:14px 0}
.section-head p{color:#4a5a50;font-size:18px}
.center{text-align:center;margin-left:auto;margin-right:auto}

/* ===== VALUE STRIP ===== */
.values{background:var(--paper);border-top:1px solid var(--mist);border-bottom:1px solid var(--mist)}
.values .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:36px}
.values .v{text-align:left}
.values .v .vk{font-family:var(--serif);font-size:23px;color:var(--pine);line-height:1.1}
.values .v .vk::before{content:"";display:block;width:26px;height:2px;background:var(--gold);margin-bottom:14px}
.values .v p{font-size:15px;color:#54635a;margin-top:8px;font-weight:300}
@media(max-width:760px){.values .grid{grid-template-columns:1fr 1fr;gap:28px}}
@media(max-width:440px){.values .grid{grid-template-columns:1fr}}
.values .strip{text-align:center;font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:var(--pine);font-weight:400;line-height:2.2}
.values .strip span{color:var(--gold);padding:0 12px}
.trust{display:grid;grid-template-columns:repeat(3,1fr);gap:44px;text-align:center;align-items:center}
.trust .titem{position:relative;padding:0 8px}
.trust .titem+.titem::before{content:"";position:absolute;left:-22px;top:50%;transform:translateY(-50%);height:56px;width:1px;background:rgba(106,118,109,.22)}
.trust .gd-logo{height:24px;width:auto;margin:0 auto 12px;display:block}
.trust h3{font-family:var(--serif);font-size:clamp(21px,2.1vw,25px);color:var(--pine);font-weight:500;line-height:1.25}
.trust .sub{font-size:15.5px;color:#6a766d;font-weight:300;margin-top:7px}
@media(max-width:760px){
  .trust{grid-template-columns:1fr;gap:38px}
  .trust .titem+.titem::before{display:none}
  .trust .gd-logo{height:26px}
  .trust h3{font-size:24px}
  .trust .sub{font-size:16px}
}

/* ===== EXCLUSIVE ACCESS ===== */
/* ===== PROOF / BY THE NUMBERS ===== */
.proof{background:var(--paper);border-top:1px solid var(--mist);padding:84px 0}
.proof-wrap{display:grid;grid-template-columns:1.05fr 1fr;gap:60px;align-items:center}
@media(max-width:880px){.proof-wrap{grid-template-columns:1fr;gap:36px}}
.proof figure{margin:0}
.proof figure img{width:100%;aspect-ratio:3/2;object-fit:cover;border-radius:2px;box-shadow:var(--lift)}
.proof figcaption{font-size:14.5px;color:#6a766d;margin-top:12px;font-weight:300}
.proof .ph2{font-size:clamp(28px,3.4vw,38px);color:var(--pine);margin:12px 0 18px}
.proof .pbody{font-size:18px;color:#4a5a50;margin:0 0 16px;max-width:56ch}
.proof .pbody:last-of-type{margin-bottom:30px}
.proof .stats{display:flex;flex-direction:column;gap:24px}
.proof .stat{border-left:2px solid var(--gold);padding-left:20px}
.proof .stat h3{font-family:var(--serif);font-size:clamp(23px,2.6vw,30px);line-height:1.2;color:var(--cinnabar);font-weight:500}
.proof .stat h3 em{font-style:normal;color:var(--cinnabar);font-weight:600}
.proof .stat p{font-size:16px;color:#6a766d;margin-top:5px;font-weight:300}
.proof .legends{font-family:var(--serif);font-style:italic;font-size:clamp(18px,2vw,22px);color:var(--pine);margin-top:32px;max-width:40ch}
@media(max-width:880px){
  .proof{padding:64px 0}
  .proof .ph2{margin-bottom:24px}
  .proof .stats{gap:20px}
  .proof .stat{padding-left:16px}
  .proof .stat h3{font-size:20px}
  .proof .legends{margin-top:26px;font-size:18px}
}

.access{background:var(--ink);color:#fff}
.access .section-head{max-width:760px}
.access .section-head h2{color:#fff}
.access .section-head p{color:rgba(255,255,255,.78)}
.access .claim{font-family:var(--serif);font-style:italic;font-size:clamp(20px,2.6vw,28px);color:#e8cf95;margin:-18px 0 50px;max-width:34ch}
.access-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:30px}
@media(max-width:820px){.access-grid{grid-template-columns:1fr}}
.access .pillar{border-top:2px solid var(--gold);padding-top:22px}
.access .pillar .pk{font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:500}
.access .pillar h4{font-size:22px;margin:10px 0 8px;color:#fff}
.access .pillar p{font-size:17px;color:rgba(255,255,255,.8);font-weight:300}
.access .pillar p+p{margin-top:9px}
.access .section-head p+p{margin-top:12px}

/* ===== WHY CHINA ===== */
.whychina{background:var(--ivory)}
.wc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--mist);border:1px solid var(--mist)}
@media(max-width:920px){.wc-grid{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.wc-grid{grid-template-columns:1fr}}
.wc-item{background:var(--paper);padding:34px 30px}
.wc-item .num{font-family:var(--serif);font-size:22px;color:var(--cinnabar);line-height:1}
.wc-item h4{font-size:20px;color:var(--pine);margin:14px 0 10px}
.wc-item p{font-size:15.5px;color:#54635a}

/* ===== FEATURED DESTINATIONS ===== */
.dest{background:var(--pine);color:#fff}
.dest .section-head h2{color:#fff}.dest .section-head p{color:rgba(255,255,255,.72)}
.dest-grid{display:grid;grid-template-columns:1fr 1fr;gap:26px}
@media(max-width:860px){.dest-grid{grid-template-columns:1fr}}
.bigcard{background:#22422f;border:1px solid rgba(255,255,255,.1);border-radius:2px;overflow:hidden;transition:.35s;display:flex;flex-direction:column}
.bigcard:hover{transform:translateY(-6px);border-color:var(--gold)}
.bigcard{cursor:pointer}
.bigcard .img{position:relative;height:260px}
.bigcard .img img{width:100%;height:100%;object-fit:cover}
.bigcard .img .tag{position:absolute;left:0;bottom:0;background:var(--cinnabar);color:#fff;font-size:11px;letter-spacing:.12em;text-transform:uppercase;padding:6px 14px}
.bigcard .c{padding:30px 30px 32px;display:flex;flex-direction:column;flex:1}
.bigcard .c .region{font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold)}
.bigcard .c h3{font-size:28px;margin:5px 0 0}
.bigcard .c .tagline{font-size:15.5px;color:rgba(255,255,255,.72);margin:6px 0 18px;font-weight:300}
.bigcard dl{display:grid;grid-template-columns:auto 1fr;gap:10px 16px;border-top:1px solid rgba(255,255,255,.16);padding-top:16px}
.bigcard dt{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);padding-top:2px}
.bigcard dd{font-size:15px;color:rgba(255,255,255,.86);font-weight:300}
.bigcard .c .bodycopy{border-top:1px solid rgba(255,255,255,.16);padding-top:16px;display:grid;gap:10px}
.bigcard .c .bodycopy p{font-size:16.5px;color:rgba(255,255,255,.86);font-weight:300}
.bigcard .c .foot{margin-top:auto;padding-top:20px}
.bigcard .c .foot a{font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:#fff;border-bottom:1px solid var(--gold);padding-bottom:3px}
.bigcard .c .foot a:hover{color:var(--gold)}

/* ===== DESTINATIONS MAP ===== */
.dest-intro{display:grid;grid-template-columns:1fr 1.1fr;gap:60px;align-items:center;margin-bottom:58px}
.dest-intro .section-head{margin-bottom:0}
@media(max-width:920px){.dest-intro{grid-template-columns:1fr;gap:36px}}
.chinamap{width:100%;height:auto;display:block}
.chinamap .land{fill:rgba(255,255,255,.055);stroke:rgba(184,145,80,.5);stroke-width:1.1;stroke-linejoin:round}
.chinamap .pin{cursor:pointer}
.chinamap .pin .dot{fill:var(--gold);transition:.25s}
.chinamap .pin .ring{fill:none;stroke:var(--gold);stroke-width:1}
.chinamap .pin .tick{stroke:rgba(184,145,80,.65);stroke-width:1}
.chinamap .pin text{font-family:var(--sans);font-size:12px;letter-spacing:.16em;text-transform:uppercase;fill:rgba(255,255,255,.88);transition:.25s}
.chinamap .pin:hover .dot{fill:#e8cf95}
.chinamap .pin:hover text{fill:var(--gold)}
.mapnote{margin-top:12px;font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.4);text-align:center}
.bigcard.flash{border-color:var(--gold)}

/* ===== SIGNATURE COURSES ===== */
.courses{background:var(--paper)}
.course-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:920px){.course-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.course-grid{grid-template-columns:1fr}}
.ccard{background:var(--ivory);border:1px solid var(--mist);border-radius:2px;overflow:hidden;transition:.35s;display:flex;flex-direction:column}
.ccard:hover{transform:translateY(-6px);box-shadow:var(--lift)}
.ccard .img{position:relative;height:208px}
.ccard .img img{width:100%;height:100%;object-fit:cover}
.ccard .img .tag{position:absolute;left:0;bottom:0;background:rgba(20,36,28,.82);color:#fff;font-size:11px;letter-spacing:.12em;text-transform:uppercase;padding:5px 12px}
.ccard.select .img .tag{background:var(--cinnabar)}
.ccard .rankline{font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);font-weight:500;margin:-4px 0 12px}
.ccard.noir{background:#0e0e0c;border-color:#2c271d}
.ccard.noir .img .tag{background:var(--gold);color:var(--ink);font-weight:600}
.ccard.noir .c .region{color:var(--gold)}
.ccard.noir .c h3{color:#e8cf95}
.ccard.noir .c p{color:rgba(232,207,149,.8)}
.ccard.noir .c .meta{border-top-color:rgba(184,145,80,.35);color:rgba(232,207,149,.65)}
.ccard.noir .c .meta span b{color:var(--gold)}
.ccard.noir:hover{box-shadow:0 22px 55px -18px rgba(0,0,0,.75)}
.ccard .c{padding:24px;display:flex;flex-direction:column;flex:1}
.ccard .c .region{font-size:13px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold)}
.ccard .c h3{font-size:23px;margin:4px 0 10px;color:var(--pine)}
.ccard .c p{font-size:16.5px;color:#54635a;font-weight:300}
.ccard .c p+p{margin-top:8px}
.ccard .c .meta{margin-top:16px;border-top:1px solid var(--mist);padding-top:13px;font-size:14px;color:#6a766d;display:flex;flex-direction:column;gap:5px}
.ccard .c .meta span b{color:var(--pine);font-weight:500}
.courses .note{text-align:center;margin-top:38px;font-size:17px;color:#54635a}
.courses .note b{color:var(--cinnabar);font-weight:500}
.ccard.more{display:none}
.courses.show-all .ccard.more{display:flex}
.more-wrap{text-align:center;margin-top:42px}
.btn-more{background:transparent;border:1px solid var(--pine);color:var(--pine)}
.btn-more:hover{background:var(--pine);color:#fff}
.more-wrap .sub{margin-top:12px;font-size:15px;letter-spacing:.04em;color:#6a766d}
.courses.show-all .more-wrap .sub{display:none}

/* ===== SAMPLE JOURNEYS ===== */
.journeys{background:var(--ivory)}
.sj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:920px){.sj-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.sj-grid{grid-template-columns:1fr}}
.sjcard{position:relative;display:flex;flex-direction:column;border-radius:8px;overflow:hidden;background:#d4c6a6;box-shadow:var(--lift)}
.sjcard.signature{box-shadow:0 0 0 2px var(--gold),var(--lift)}
.sjcard .sj-badge{position:absolute;left:16px;top:16px;z-index:3;background:#d4c6a6;color:var(--ink);font-size:11px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;padding:8px 16px;border-radius:999px}
.sjcard .ph{overflow:hidden}
.sjcard .ph img{width:100%;aspect-ratio:4/3;object-fit:cover;transition:.5s}
.sjcard:hover .ph img{transform:scale(1.05)}
.sjcard .b{padding:26px 26px 24px;flex:1}
.sjcard h3{font-size:30px;line-height:1.12}
.sjcard .specs{font-size:13px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--ink);margin-top:10px}
.sjcard .hi{font-size:16px;color:rgba(20,36,28,.85);margin-top:14px;font-weight:300}
.sjcard .hi p+p{margin-top:8px}
.sjcard .tl{font-size:13.5px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;margin-top:18px}
.sjcard .route{font-size:16px;color:rgba(20,36,28,.8);font-weight:300;margin-top:2px}
.sjcard .bestfor{font-size:14px;font-style:italic;color:rgba(20,36,28,.65);margin-top:12px;font-weight:300}
.sjcard .foot{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:18px 26px;background:var(--paper);border-top:1px solid rgba(20,36,28,.18)}
.sjcard .price{font-size:16.5px;font-weight:300}
.sjcard .price b{font-weight:600}
.sjcard .foot a{background:var(--ink);color:#fff;font-size:14px;font-weight:500;padding:13px 24px;border-radius:12px;white-space:nowrap;transition:.25s}
.sjcard .foot a:hover{background:var(--pine)}
.journeys .note{text-align:center;margin-top:40px;font-size:14px;color:#54635a}

/* ===== SIGNATURE EXPERIENCES ===== */
.exclusives{background:var(--paper);border-top:1px solid var(--mist)}
.ex-carousel{position:relative}
.ex-track{display:flex;gap:20px;overflow-x:auto;overflow-y:hidden;padding:4px 4px 18px;scrollbar-width:none;-webkit-overflow-scrolling:touch}
.ex-track::-webkit-scrollbar{display:none}
.excard{position:relative;flex:0 0 min(340px,80vw);height:450px;border-radius:2px;overflow:hidden;color:#fff;display:flex;align-items:flex-end;box-shadow:var(--lift)}
.excard img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:.5s}
@media(hover:hover){.excard:hover img{transform:scale(1.05)}}
.excard .kind{position:absolute;top:14px;left:14px;z-index:2;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:500;color:#fff;background:rgba(20,36,28,.5);backdrop-filter:blur(4px);padding:6px 11px;border-radius:2px}
.excard .b{position:relative;z-index:2;padding:24px;width:100%;background:linear-gradient(180deg,transparent,rgba(20,36,28,.55) 30%,rgba(20,36,28,.92));text-shadow:0 1px 10px rgba(20,36,28,.5)}
.excard .loc{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:#e8cf95;font-weight:500}
.excard h3{font-size:23px;margin:6px 0 7px}
